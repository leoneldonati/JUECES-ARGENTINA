---
import Layout from "~/layouts/Layout.astro";
import MagistradosTable from "~/components/MagistradosTable.tsx";

import magistradosRaw from "~/data/magistrados.json";
import metadataRow from "~/data/metadata.json";

const { magistrados } = magistradosRaw;
const { lastUpdated, source } = metadataRow;
---

<Layout title="Tracker de Jueces Argentina">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10">
    <!-- Header -->
    <div class="mb-12">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6">
        <div>
          <h1 class="text-4xl font-bold tracking-tight text-gray-900">
            Tracker de Jueces y Magistrados
          </h1>
          <p class="mt-3 text-lg text-gray-600">{source}</p>
        </div>

        <div class="text-sm text-gray-500 text-right">
          <p>
            Última actualización: <span class="font-medium text-gray-700">
              {
                new Date(lastUpdated).toLocaleDateString("es-AR", {
                  day: "numeric",
                  month: "long",
                  year: "numeric",
                })
              }
            </span>
          </p>
          <p class="mt-1">
            Total: <span class="font-semibold text-gray-900"
              >{magistrados.length.toLocaleString("es-AR")}</span
            > magistrados
          </p>
        </div>
      </div>
    </div>

    <!-- Tabla React -->
    <MagistradosTable client:load magistrados={magistrados} />
  </div>
</Layout>
